{
  "version": 2,
  "builds": [
    {
      "src": "dist/lambda.js",
      "use": "@vercel/node",
      "config": {
        "memory": 1024,
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/dist/lambda.js"
    },
    {
      "src": "/api(.*)",
      "dest": "/dist/lambda.js"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/lambda.js"
    }
  ]
}
